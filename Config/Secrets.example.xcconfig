// Copy this file to Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored and must never be committed.
//
// NOTE on "//": xcconfig treats "//" as a line comment, even inside URLs.
// Escape it in URLs as "/$()/", e.g. https:/$()/example.com

// Base URL for the kabuto /api/v1 layer (Next.js backend).
// Example: https:/$()/kabuto.example.com
KABUTO_API_BASE_URL = https:/$()/kabuto.example.com

// Supabase project URL and anon (publishable) key.
// Find in Supabase dashboard → Project Settings → API.
KABUTO_SUPABASE_URL = https:/$()/YOUR-PROJECT.supabase.co
KABUTO_SUPABASE_ANON_KEY = YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY
