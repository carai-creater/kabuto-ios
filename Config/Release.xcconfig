// Release configuration
#include? "Secrets.xcconfig"

SWIFT_ACTIVE_COMPILATION_CONDITIONS =
GCC_PREPROCESSOR_DEFINITIONS =

PRODUCT_BUNDLE_IDENTIFIER = com.carai.kabuto
PRODUCT_NAME = Kabuto
MARKETING_VERSION = 0.1.2
CURRENT_PROJECT_VERSION = 3

KABUTO_API_BASE_URL = $(KABUTO_API_BASE_URL)
KABUTO_SUPABASE_URL = $(KABUTO_SUPABASE_URL)
KABUTO_SUPABASE_ANON_KEY = $(KABUTO_SUPABASE_ANON_KEY)

INFOPLIST_KEY_KabutoAPIBaseURL = $(KABUTO_API_BASE_URL)
INFOPLIST_KEY_KabutoSupabaseURL = $(KABUTO_SUPABASE_URL)
INFOPLIST_KEY_KabutoSupabaseAnonKey = $(KABUTO_SUPABASE_ANON_KEY)
